# Frontend (Vite) → Contact API integration
# Copy to .env.local and adjust for your environment.
VITE_API_URL=http://localhost:5236
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Backend secrets do NOT live in this file.
# Local dev:  dotnet user-secrets set "Resend:ApiKey" "re_..."
# Production: set as env vars on Render (ConnectionStrings__Default,
#             Resend__ApiKey, Resend__FromAddress, Resend__ToAddress,
#             Turnstile__SecretKey).
